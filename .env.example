PORT=3000
NODE_ENV=development

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

DATAVERSE_BASE_URL=https://your-org.crm.dynamics.com
DATAVERSE_API_VERSION=v9.2
AAD_TENANT_ID=your-entra-tenant-id
DATAVERSE_CLIENT_ID=your-dataverse-app-id
DATAVERSE_CLIENT_SECRET=your-dataverse-app-secret

HTTP_TOOL_TIMEOUT_MS=15000
MAX_TOOL_ITERATIONS=5
MCP_ALLOWED_HOSTS=api.example.com,mcp.example.com
